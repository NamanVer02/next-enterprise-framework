{
  "collections": [
    {
      "name": "car_models",
      "type": "base",
      "schema": [
        {
          "name": "name",
          "type": "text",
          "required": true
        },
        {
          "name": "tagline",
          "type": "text",
          "required": true
        },
        {
          "name": "description",
          "type": "text",
          "required": true
        },
        {
          "name": "badge_text",
          "type": "text",
          "required": false
        },
        {
          "name": "hero_image",
          "type": "file",
          "required": false,
          "options": {
            "maxSelect": 1,
            "maxSize": 5242880,
            "mimeTypes": ["image/jpeg", "image/png", "image/webp"]
          }
        }
      ]
    }
  ]
}
